{
    "layer": "top",
    "spacing": 0,
    "height": 0,

    "margin-top": 8,
    "margin-right": 19,
    "margin-bottom": 0,
    "margin-left": 19,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
        //"hyprland/language"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "image",
        "tray",
        "backlight",
        "cpu",
        "memory",
        "network",
        "pulseaudio",
        "battery",
        "custom/kanata",
        "custom/power"
        //"cava"
    ],

    "custom/kanata":{
        "exec": "~/.config/waybar/kanata_layout_indicator.sh",
        "format": "{text}"
    },

    "custom/power": {
        "format": "тП╗",
        "tooltip": false,
        "menu": "on-click",
        "menu-file": "~/.config/waybar/power_menu.xml",
        "menu-actions": {
            "shutdown": "shutdown now",
            "reboot": "reboot now",
            "suspend": "systemctl suspend",
            "hibernate": "systemctl hibernate"
        }
    },

    // TODO: Fix cava :(
    "cava": {
        "cava_config": "~/.config/cava/cava",
        "framerate": 30,
        "autosens": 1,
        "sensitivity": 100,
        "bars": 14,
        "lower_cutoff_freq": 50,
        "higher_cutoff_freq": 10000,
        "hide_on_silence": false,
        // "format_silent": "quiet",
        "method": "pulse",
        "source": "auto",
        "stereo": true,
        "reverse": false,
        "bar_delimiter": 0,
        "monstercat": false,
        "waves": false,
        "noise_reduction": 0.77,
        "input_delay": 2,
        "format-icons": ["тЦБ", "тЦВ", "тЦГ", "тЦД", "тЦЕ", "тЦЖ", "тЦЗ", "тЦИ" ],
        "actions": {
                   "on-click-right": "mode"
                   }
    },

    // TODO: fix the spotify img
    "image#album-art": {
        "path": "/tmp/mpd_art",
        "size": 32,
        "interval": 5,
        "on-click": "mpc toggle"
    },

    "image/album-art": {
        "exec":"~/.config/waybar/custom/spotify/album_art.sh",
        "size": 32,
        "interval": 30
    },

    "backlight": {
        "device": "amdgpu_bl1",
        "format": "{icon} {percent}%",
        "format-icons": ["яУГ", "яЖЕ", "яДС"],
	    "on-click": "~/scripts/wlsunset_toggle.sh"
    },
    
    "hyprland/workspaces": {
        "format": "{icon} {windows} ",
        "format-icons": {
            "default": "яУГ",
            "active": "яЖТ",    
            "urgent": "ґ░Аж"     
        },
        "persistent-only": true,
        "persistent-workspaces": {
		"*": 4
	    },
        "window-rewrite-default": "юко",
        "window-rewrite": {
            "kitty": "юЮХ",
            "obs": "ґ░СЛ",
            "dolphin": "ґ░к╢",
            "Spotify": "яЖ╝",
            "title<.*youtube.*>": "яЕк", // Windows whose titles contain "youtube"
            "brave": "ґ░ЦЯ", // Windows whose classes are "firefox"
            "brave title<.*github.*>": "яДУ", // Windows whose class is "firefox" and title contains "github". Note that "class" always comes first.
            "foot": "юЮХ", // Windows that contain "foot" in either class or title. For optimization reasons, it will only match against a title if at least one other window explicitly matches against a title.
            "code": "ґ░иЮ"
        }
    },

    "tray": {
        "spacing": 10,
        "tooltip": false
    },

    "clock": {
        "format": "{:%H:%M - %a, %d %b %Y}",
        "tooltip": false
    },

    "cpu": {
        "format": "яТ╝ {usage}%",
        "interval": 2,

        "states": {
            "critical": 90
        }
    },

    "memory": {
        "format": "ю┐Е {percentage}%",
        "interval": 2,

        "states": {
            "critical": 80
        },

        "tooltip-format": "{used:0.1f} / {total:0.1f} GiB\n{swapUsed:0.1f} / {swapTotal:0.1f} GiB (SWAP)"
    },

    "battery": {
        "format": "{icon}",
        "format-icons": ["яЙД","яЙГ","яЙВ","яЙБ","яЙА"],
        "interval": 5,
        "states": {
            "warning": 20,
            "critical": 10
        },
        "tooltip": true,
        "tooltip-format": "{timeTo}\nю║Ю {capacity}%\nяИЮ {health}%"
    },

    "network": {
        "format-wifi" : "wifi {bandwidthDownBits}",
        "format-ethernet": "eth {bandwidthDownBits}",
        "format-disconnected" : "no network",
        "interval": 5,
        "tooltip": false
    },

    "pulseaudio": {
        "scroll-step": 5,
        "max-volume": 150,
        "format": "{volume}% {icon} ",
        "format-bluetooth": "{volume}% {icon} ",
        "format-muted": "ґ░ЦБ",
        "format-icons": {
            "default": ["яАж","яАз","яАи"],
            "headset": "яАе",
            "headphone": "яАе"
        },
        "nospacing": 1,
        "on-click": "pavucontrol",
        "tooltip": true,
        "tooltip-format": "{desc}\n{format_source}"
    }
}
